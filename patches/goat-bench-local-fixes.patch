+    @staticmethod
+    def _safe_close_envs(envs) -> None:
+        if envs is None or getattr(envs, "_is_closed", True):
+            return
+
+        for read_fn in getattr(envs, "_connection_read_fns", []):
+            try:
+                if getattr(read_fn, "is_waiting", False):
+                    read_fn()
+            except Exception as err:
+                logger.warning(f"Ignoring VectorEnv read during close: {err}")
+
+        for write_fn in getattr(envs, "_connection_write_fns", []):
+            try:
+                write_fn((CLOSE_COMMAND, None))
+            except Exception as err:
+                logger.warning(f"Ignoring VectorEnv close command failure: {err}")
+
+        for _, _, write_fn, _ in getattr(envs, "_paused", []):
+            try:
+                write_fn((CLOSE_COMMAND, None))
+            except Exception as err:
+                logger.warning(f"Ignoring paused VectorEnv close failure: {err}")
+
+        for process in list(getattr(envs, "_workers", [])) + [
+            p for _, _, _, p in getattr(envs, "_paused", [])
+        ]:
+            process.join(timeout=5)
+            if process.is_alive():
+                logger.warning(
+                    f"VectorEnv worker {process.pid} did not exit; terminating."
+                )
+                process.terminate()
+                process.join(timeout=1)
+
+        envs._is_closed = True
+
